+'clients/8.jpg' },\n    { name: 'Mr. Karan Paul', role: 'Chairman, Apeejay Group', img: RL+'clients/9.jpg' },\n    { name: 'Mr. T.S. Krishnamurthy', role: 'Ex. Chief Election Commissioner', img: RL+'clients/15.jpg' },\n    { name: 'Mr. Rahul Agrawal', role: 'Owner, Comesum Group', img: RL+'clients/11.jpg' },\n    { name: 'Mr. Sanjay Tanna', role: 'MP, Uganda', img: RL+'clients/13.jpg' },\n    { name: 'Mr. Sanjeev Agrawal', role: 'Chairman, Moon Beverages', img: RL+'clients/14.jpg' },\n    { name: 'Mr. Prakash C Bisht', role: 'CFO, Jubilant Foods', img: RL+'clients/20.jpg' },\n    { name: 'Mr. Arun Samarth', role: 'Builder', img: RL+'clients/7.jpg' },\n  ];\n\n  // \u2500\u2500 BUILD EXPERTS \u2500\u2500\n  (function(){\n    const g = document.getElementById('expertsGrid');\n    experts.forEach(e => {\n      g.innerHTML += `\n        <div class=\"flip-card\">\n          <div class=\"flip-inner\">\n            <div class=\"flip-front\">\n              <div class=\"expert-photo\">\n                <img src=\"${e.img}\" alt=\"${e.name}\" onerror=\"this.parentElement.innerHTML='<div class=expert-initials>${e.name.split(' ').map(w=>w[0]).slice(0,2).join('')}</div>'\" />\n              </div>\n              <div class=\"expert-name\">${e.name}</div>\n              <div class=\"expert-title\">${e.title}</div>\n              <div class=\"expert-exp\">${e.exp}</div>\n              <div class=\"flip-tap\">Tap</div>\n            </div>\n            <div class=\"flip-back\">\n              <div class=\"back-exp\">${e.exp}</div>\n              <div class=\"back-divider\"></div>\n              <div class=\"back-name\">${e.name}</div>\n              <div class=\"back-title\">${e.title}</div>\n              <div class=\"back-divider\"></div>\n              <div class=\"back-desc\">${e.desc}</div>\n              <div class=\"back-om\">\u0950</div>\n            </div>\n          </div>\n        </div>`;\n    });\n  })();\n\n  // \u2500\u2500 BUILD PRODUCTS \u2500\u2500\n  (function(){\n    const t = document.getElementById('productTrack');\n    const all = [...products, ...products];\n    all.forEach(p => {\n      t.innerHTML += `\n        <a href=\"/start\" class=\"product-card\">\n          <img src=\"${p.img}\" alt=\"${p.name}\" onerror=\"this.style.background='#e8dfd0'\" />\n          <div class=\"product-info\"><div class=\"product-name\">${p.name}</div><div class=\"product-benefit\">${p.benefit}</div></div>\n        </a>`;\n    });\n  })();\n\n  // \u2500\u2500 BUILD CLIENTS \u2500\u2500\n  function buildClients(id, data, repeat) {\n    const el = document.getElementById(id);\n    const all = [...data, ...data];\n    all.forEach(c => {\n      el.innerHTML += `\n        <div class=\"client-card\">\n          <div class=\"client-photo\"><img src=\"${c.img}\" alt=\"${c.name}\" onerror=\"this.style.display='none'\" /></div>\n          <div class=\"client-name\">${c.name}</div>\n          <div class=\"client-role\">${c.role}</div>\n        </div>`;\n    });\n  }\n  buildClients('clientsRow1', clientsRow1);\n  buildClients('clientsRow2', clientsRow2);\n\n  // \u2500\u2500 BUILD MEDIA LOGOS \u2500\u2500\n  (function(){\n    const t = document.getElementById('mediaLogos');\n    const logos = [1,2,3,4,5,6,7,8,9,...Array.from({length:9},(_,i)=>i+1)];\n    logos.forEach(n => {\n      t.innerHTML += `<div class=\"media-logo-item\"><img src=\"${RL}media-logo/${n}-media-logo.jpg\" alt=\"Media ${n}\" onerror=\"this.style.display='none'\" /></div>`;\n    });\n  })();\n\n  // \u2500\u2500 BUILD PAYMENT GATEWAYS \u2500\u2500\n  (function(){\n    const g = document.getElementById('pgGrid');\n    for(let i=1;i<=9;i++){\n      g.innerHTML += `<div class=\"pg-item\"><img src=\"${RL}payment-gateway/pg-${i}.jpg\" alt=\"Payment ${i}\" onerror=\"this.style.display='none'\" /></div>`;\n    }\n  })();\n\n  // \u2500\u2500 COPYRIGHT YEAR \u2500\u2500\n  document.getElementById('year').textContent = new Date().getFullYear();\n\n  // \u2500\u2500 MOBILE MENU \u2500\u2500\n  function toggleMenu() {\n    const m = document.getElementById('mobileMenu');\n    m.style.display = m.style.display === 'flex' ? 'none' : 'flex';\n  }\n\n  // \u2500\u2500 FAQ ACCORDION \u2500\u2500\n  function toggleFaq(btn) {\n    const item = btn.parentElement;\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n\n  // \u2500\u2500 COUNTUP ANIMATION \u2500\u2500\n  function formatIndian(n) {\n    if (n >= 100000) {\n      const l = Math.floor(n/100000), r = Math.floor((n%100000)/1000);\n      return r > 0 ? `${l},${String(r).padStart(2,'0')},000` : `${l},00,000`;\n    }\n    return n.toLocaleString('en-IN');\n  }\n  const counters = document.querySelectorAll('.stat-num[data-target]');\n  let counted = false;\n  const io = new IntersectionObserver(entries => {\n    if (entries[0].isIntersecting && !counted) {\n      counted = true;\n      counters.forEach(el => {\n        const target = +el.dataset.target;\n        const suffix = el.dataset.suffix || (el.dataset.format === 'indian' ? '+' : '');\n        const fmt = el.dataset.format;\n        const dur = 2200;\n        const step = target / (dur / 16);\n        let cur = 0;\n        const t = setInterval(() => {\n          cur += step;\n          if (cur >= target) { cur = target; clearInterval(t); }\n          el.textContent = (fmt === 'indian' ? formatIndian(Math.floor(cur)) : Math.floor(cur).toLocaleString()) + suffix;\n        }, 16);\n      });\n    }\n  }, { threshold: 0.4 });\n  if (counters[0]) io.observe(counters[0].closest('section') || counters[0]);\n\n  // \u2500\u2500 TOUCH FLIP CARDS \u2500\u2500\n  document.querySelectorAll('.flip-card').forEach(card => {\n    card.addEventListener('click', function() {\n      const inner = this.querySelector('.flip-inner');\n      const cur = inner.style.transform;\n      inner.style.transform = cur === 'rotateY(180deg)' ? '' : 'rotateY(180deg)';\n    });\n  });\n</script>\n</body>\n</html>\n"
