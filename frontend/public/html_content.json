"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Rudralife\u00ae \u2014 Get Your Personalised Rudraksha Recommendation</title>\n  <meta name=\"description\" content=\"Get a personalised Rudraksha recommendation from India's most trusted experts. Guided by 25 years of Vedic wisdom and 5,00,000+ transformed lives.\" />\n  <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap\" rel=\"stylesheet\" />\n  <style>\n    :root {\n      --ivory: #F8F4EC;\n      --ivory2: #FBF8F2;\n      --gold: #C9A227;\n      --gold-light: #E0B830;\n      --maroon: #800000;\n      --maroon2: #9B2030;\n      --dark: #2C1E16;\n      --muted: #5C4A42;\n      --border: #E8DFD0;\n      --black: #0D0805;\n    }\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n    html { scroll-behavior: smooth; }\n    body { font-family: 'DM Sans', sans-serif; background: var(--ivory); color: var(--dark); -webkit-font-smoothing: antialiased; }\n    .serif { font-family: 'Cormorant Garamond', serif; }\n\n    /* \u2500\u2500 NAV \u2500\u2500 */\n    #hero { position: relative; min-height: 100vh; overflow: hidden; background: #000; }\n    #hero .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 60% center; }\n    #hero .hero-overlay { position: absolute; inset: 0; background: linear-gradient(95deg, rgba(0,0,0,.93) 0%, rgba(0,0,0,.85) 38%, rgba(0,0,0,.48) 62%, rgba(0,0,0,.12) 100%); }\n    #hero .hero-overlay-top { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.45) 0%, transparent 18%, transparent 80%, rgba(0,0,0,.45) 100%); }\n    nav { position: relative; z-index: 30; display: flex; align-items: center; justify-content: space-between; padding: 18px 48px; }\n    nav .logo { height: 38px; object-fit: contain; filter: drop-shadow(0 0 5px rgba(255,255,255,.9)) drop-shadow(0 0 2px rgba(255,255,255,.8)) brightness(1.3); cursor: pointer; }\n    nav .nav-links { display: flex; gap: 28px; }\n    nav .nav-links a { color: rgba(255,255,255,.75); text-decoration: none; font-size: 14px; transition: color .2s; }\n    nav .nav-links a:hover { color: #fff; }\n    nav .nav-cta { background: var(--gold); color: #1A0A00; font-weight: 600; font-size: 14px; padding: 10px 24px; border-radius: 999px; border: none; cursor: pointer; text-decoration: none; transition: background .2s, transform .2s; box-shadow: 0 4px 16px rgba(201,162,39,.3); }\n    nav .nav-cta:hover { background: var(--gold-light); transform: translateY(-1px); }\n    .hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; }\n    .hamburger span { display: block; height: 2px; width: 24px; background: rgba(255,255,255,.8); transition: .3s; }\n    .mobile-menu { display: none; position: relative; z-index: 20; background: rgba(0,0,0,.92); border-top: 1px solid rgba(255,255,255,.1); padding: 16px 20px; flex-direction: column; gap: 12px; }\n    .mobile-menu a { color: rgba(255,255,255,.75); text-decoration: none; font-size: 14px; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.06); }\n    .mobile-menu .mob-cta { background: var(--gold); color: #1A0A00; font-weight: 600; padding: 14px; border-radius: 999px; text-align: center; margin-top: 8px; }\n\n    /* \u2500\u2500 HERO CONTENT \u2500\u2500 */\n    .hero-content { position: relative; z-index: 10; display: flex; align-items: center; min-height: calc(100vh - 72px); padding: 32px 48px; }\n    .hero-inner { max-width: 560px; }\n    .hero-badge { color: var(--gold); font-size: 11px; letter-spacing: .28em; text-transform: uppercase; margin-bottom: 24px; display: block; }\n    .hero-h1 { font-family: 'Cormorant Garamond', serif; font-weight: 300; color: #fff; line-height: 1.05; font-size: clamp(44px, 8vw, 96px); }\n    .hero-h1-gold { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-style: italic; color: var(--gold); line-height: 1.05; font-size: clamp(44px, 8vw, 96px); margin-bottom: 28px; display: block; }\n    .hero-quote { color: rgba(255,255,255,.65); font-size: 14px; line-height: 1.7; font-style: italic; max-width: 400px; margin-bottom: 32px; }\n    .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }\n    .btn-gold { background: var(--gold); color: #1A0A00; font-weight: 600; font-size: 14px; padding: 16px 36px; border-radius: 999px; border: none; cursor: pointer; transition: background .2s, transform .2s, box-shadow .2s; box-shadow: 0 4px 24px rgba(201,162,39,.25); text-decoration: none; display: inline-block; }\n    .btn-gold:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(201,162,39,.3); }\n    .btn-outline-white { border: 1px solid rgba(255,255,255,.35); color: #fff; background: transparent; font-weight: 600; font-size: 14px; padding: 16px 32px; border-radius: 999px; cursor: pointer; transition: background .2s, border-color .2s; text-decoration: none; display: inline-block; }\n    .btn-outline-white:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.6); }\n    .trust-chips { display: flex; flex-wrap: wrap; gap: 16px 20px; color: rgba(255,255,255,.45); font-size: 12px; }\n    .trust-chips span { display: flex; align-items: center; gap: 6px; }\n    .trust-chips .dot { width: 12px; height: 12px; background: rgba(201,162,39,.8); border-radius: 50%; flex-shrink: 0; }\n    .scroll-hint { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px; opacity: .3; animation: bounce 2s infinite; }\n    .scroll-hint .line { width: 1px; height: 20px; background: #fff; }\n    .scroll-hint svg { color: #fff; }\n    @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }\n\n    /* \u2500\u2500 STATS \u2500\u2500 */\n    #stats { background: var(--maroon); padding: 36px 0; }\n    .stats-grid { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }\n    .stat-item { text-align: center; }\n    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 3.5vw, 44px); font-weight: 600; color: #F0C050; }\n    .stat-label { color: rgba(255,255,255,.75); font-size: 13px; margin-top: 4px; }\n\n    /* \u2500\u2500 SECTIONS \u2500\u2500 */\n    .section { padding: 72px 24px; }\n    .section-inner { max-width: 1200px; margin: 0 auto; }\n    .section-eyebrow { color: var(--maroon); font-size: 11px; letter-spacing: .3em; text-transform: uppercase; margin-bottom: 12px; display: block; }\n    .section-heading { font-family: 'Cormorant Garamond', serif; font-weight: 300; color: var(--dark); font-size: clamp(28px, 4vw, 52px); margin-bottom: 16px; }\n    .section-sub { color: var(--muted); font-size: 15px; line-height: 1.7; max-width: 560px; }\n    .section-divider { display: flex; align-items: center; gap: 16px; margin: 20px 0; }\n    .section-divider .line { height: 1px; background: rgba(201,162,39,.4); flex: 1; }\n    .section-divider .dot { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; }\n\n    /* \u2500\u2500 QUOTE \u2500\u2500 */\n    #quote { background: var(--ivory); text-align: center; }\n    .quote-shloka { font-family: 'Cormorant Garamond', serif; font-style: italic; color: var(--maroon); font-size: clamp(22px, 3vw, 36px); font-weight: 300; line-height: 1.5; margin-bottom: 20px; }\n    .quote-text { font-family: 'Cormorant Garamond', serif; font-size: clamp(18px, 2.2vw, 26px); color: var(--dark); font-style: italic; line-height: 1.6; max-width: 640px; margin: 0 auto 12px; }\n    .quote-source { color: var(--muted); font-size: 12px; letter-spacing: .2em; text-transform: uppercase; opacity: .6; }\n\n    /* \u2500\u2500 HOW IT WORKS \u2500\u2500 */\n    #how { background: var(--ivory2); }\n    .how-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 48px; }\n    .how-card { background: #fff; border-radius: 20px; border: 1px solid var(--border); padding: 24px; position: relative; transition: box-shadow .3s, transform .3s; }\n    .how-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); transform: translateY(-4px); }\n    .how-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--gold), transparent); border-radius: 20px 20px 0 0; }\n    .how-step { width: 40px; height: 40px; border-radius: 50%; background: rgba(128,0,0,.08); border: 1px solid rgba(128,0,0,.15); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; color: var(--maroon); font-weight: 600; font-size: 14px; margin-bottom: 16px; }\n    .how-title { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 600; color: var(--dark); margin-bottom: 8px; }\n    .how-desc { font-size: 13px; color: var(--muted); line-height: 1.65; }\n    .how-arrow { display: none; position: absolute; right: -12px; top: 50%; transform: translateY(-50%); width: 24px; height: 24px; border-radius: 50%; background: rgba(201,162,39,.15); border: 1px solid rgba(201,162,39,.3); align-items: center; justify-content: center; color: var(--gold); font-size: 14px; z-index: 1; }\n\n    /* \u2500\u2500 EXPERTS \u2500\u2500 */\n    #experts { background: var(--ivory2); }\n    .experts-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 16px; margin-top: 40px; }\n    .flip-card { height: 340px; perspective: 1200px; cursor: pointer; }\n    .flip-inner { position: relative; width: 100%; height: 100%; transform-style: preserve-3d; transition: transform .7s cubic-bezier(.4,0,.2,1); }\n    .flip-card:hover .flip-inner { transform: rotateY(180deg); }\n    .flip-front, .flip-back { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; border-radius: 18px; border: 1px solid var(--border); overflow: hidden; }\n    .flip-front { background: #fff; display: flex; flex-direction: column; align-items: center; padding: 20px 12px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }\n    .flip-front::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }\n    .expert-photo { width: 110px; height: 110px; border-radius: 50%; overflow: hidden; border: 2.5px solid var(--gold); box-shadow: 0 4px 20px rgba(201,162,39,.15); flex-shrink: 0; background: #f0e8d8; }\n    .expert-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 10%; }\n    .expert-initials { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #FBF5E6, #F0E5C8); font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--maroon); }\n    .expert-name { font-family: 'Cormorant Garamond', serif; font-size: 14px; font-weight: 600; color: var(--dark); text-align: center; margin-top: 12px; margin-bottom: 4px; }\n    .expert-title { font-size: 11px; color: var(--maroon); text-align: center; line-height: 1.4; }\n    .expert-exp { color: var(--gold); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; margin-top: auto; padding-top: 8px; }\n    .flip-tap { color: var(--gold); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; opacity: .4; margin-top: 6px; }\n    .flip-back { background: linear-gradient(160deg, #FDF5F7 0%, #FBF8F0 100%); transform: rotateY(180deg); padding: 20px; display: flex; flex-direction: column; }\n    .flip-back::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, rgba(128,0,0,.4), var(--maroon), rgba(128,0,0,.4)); }\n    .back-exp { display: inline-block; background: rgba(128,0,0,.08); border: 1px solid rgba(128,0,0,.2); color: var(--maroon); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; padding: 4px 12px; border-radius: 999px; text-align: center; margin-bottom: 10px; }\n    .back-name { font-family: 'Cormorant Garamond', serif; font-size: 15px; font-weight: 600; color: var(--dark); text-align: center; }\n    .back-title { font-size: 11px; color: var(--maroon); text-align: center; margin-bottom: 8px; }\n    .back-divider { height: 1px; background: rgba(201,162,39,.3); margin: 8px 0; }\n    .back-desc { font-size: 12px; color: var(--muted); line-height: 1.6; text-align: center; flex: 1; }\n    .back-om { font-family: 'Cormorant Garamond', serif; color: rgba(201,162,39,.2); font-size: 28px; text-align: center; margin-top: 8px; }\n\n    /* \u2500\u2500 MARQUEE \u2500\u2500 */\n    .marquee-wrap { overflow: hidden; position: relative; }\n    .marquee-wrap::before, .marquee-wrap::after { content: ''; position: absolute; top: 0; bottom: 0; width: 80px; z-index: 2; pointer-events: none; }\n    .marquee-wrap::before { left: 0; }\n    .marquee-wrap::after { right: 0; }\n    .marquee-ivory::before { background: linear-gradient(90deg, var(--ivory), transparent); }\n    .marquee-ivory::after { background: linear-gradient(-90deg, var(--ivory), transparent); }\n    .marquee-ivory2::before { background: linear-gradient(90deg, var(--ivory2), transparent); }\n    .marquee-ivory2::after { background: linear-gradient(-90deg, var(--ivory2), transparent); }\n    .marquee-track { display: flex; gap: 12px; width: max-content; }\n    .marquee-fwd { animation: mfwd 35s linear infinite; }\n    .marquee-rev { animation: mrev 38s linear infinite; }\n    .marquee-wrap:hover .marquee-track { animation-play-state: paused; }\n    @keyframes mfwd { from{transform:translateX(0)} to{transform:translateX(-50%)} }\n    @keyframes mrev { from{transform:translateX(-50%)} to{transform:translateX(0)} }\n\n    /* \u2500\u2500 PRODUCTS \u2500\u2500 */\n    #products { background: var(--ivory2); }\n    .product-card { flex-shrink: 0; width: 220px; border-radius: 18px; overflow: hidden; border: 1px solid var(--border); background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,.05); transition: box-shadow .3s, transform .3s; cursor: pointer; }\n    .product-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.1); transform: translateY(-4px); }\n    .product-card img { width: 100%; height: 170px; object-fit: cover; }\n    .product-info { padding: 12px 14px; }\n    .product-name { font-family: 'Cormorant Garamond', serif; font-size: 14px; font-weight: 600; color: var(--dark); margin-bottom: 4px; }\n    .product-benefit { font-size: 11px; color: var(--muted); line-height: 1.5; }\n\n    /* \u2500\u2500 TRUSTED \u2500\u2500 */\n    #trusted { background: var(--ivory); }\n    .client-card { flex-shrink: 0; width: 150px; display: flex; flex-direction: column; align-items: center; }\n    .client-photo { width: 82px; height: 82px; border-radius: 50%; overflow: hidden; border: 2px solid var(--gold); background: var(--border); margin-bottom: 8px; box-shadow: 0 2px 12px rgba(201,162,39,.12); }\n    .client-photo img { width: 100%; height: 100%; object-fit: cover; }\n    .client-name { font-family: 'Cormorant Garamond', serif; font-size: 12px; font-weight: 600; color: var(--dark); text-align: center; line-height: 1.3; }\n    .client-role { font-size: 10px; color: var(--muted); text-align: center; line-height: 1.3; margin-top: 2px; opacity: .7; }\n\n    /* \u2500\u2500 VIDEO TESTIMONIALS \u2500\u2500 */\n    #testimonials { background: var(--ivory); }\n    .video-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }\n    .video-thumb { border-radius: 18px; overflow: hidden; border: 1px solid var(--border); cursor: pointer; position: relative; transition: box-shadow .3s, transform .3s; display: block; text-decoration: none; }\n    .video-thumb:hover { box-shadow: 0 12px 40px rgba(0,0,0,.12); transform: translateY(-4px); }\n    .video-thumb img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; transition: transform .5s; }\n    .video-thumb:hover img { transform: scale(1.05); }\n    .video-thumb .overlay { position: absolute; inset: 0; background: rgba(44,30,22,.2); transition: background .3s; }\n    .video-thumb:hover .overlay { background: rgba(44,30,22,.1); }\n    .video-thumb .play-btn { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 52px; height: 52px; border-radius: 50%; background: rgba(255,255,255,.9); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(0,0,0,.2); transition: transform .3s, background .3s; }\n    .video-thumb:hover .play-btn { transform: translate(-50%,-50%) scale(1.1); background: #fff; }\n    .play-icon { width: 0; height: 0; border-top: 10px solid transparent; border-bottom: 10px solid transparent; border-left: 18px solid var(--maroon); margin-left: 3px; }\n\n    /* \u2500\u2500 FEATURED \u2500\u2500 */\n    #featured { background: var(--ivory2); }\n    .video-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 48px; }\n    .video-card { background: #fff; border-radius: 20px; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(0,0,0,.05); cursor: pointer; transition: box-shadow .3s, transform .3s; text-decoration: none; display: block; }\n    .video-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,.1); transform: translateY(-4px); }\n    .video-card .thumb { position: relative; overflow: hidden; }\n    .video-card .thumb img { width: 100%; height: 200px; object-fit: cover; transition: transform .5s; }\n    .video-card:hover .thumb img { transform: scale(1.05); }\n    .video-card .thumb .voverlay { position: absolute; inset: 0; background: rgba(44,30,22,.3); transition: background .3s; }\n    .video-card:hover .thumb .voverlay { background: rgba(44,30,22,.2); }\n    .video-card .thumb .vplay { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 58px; height: 58px; border-radius: 50%; background: rgba(255,255,255,.9); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(0,0,0,.2); transition: transform .3s; }\n    .video-card:hover .thumb .vplay { transform: translate(-50%,-50%) scale(1.1); }\n    .outlet-tag { position: absolute; top: 12px; left: 12px; background: var(--maroon); color: #fff; font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 999px; }\n    .video-card .body { padding: 18px; }\n    .video-card .vtitle { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 600; color: var(--dark); margin-bottom: 6px; }\n    .video-card .vdesc { font-size: 12px; color: var(--muted); line-height: 1.6; }\n    .video-card .vlink { display: flex; align-items: center; gap: 6px; color: var(--maroon); font-size: 12px; margin-top: 10px; }\n    .media-logos { display: flex; justify-content: center; padding: 28px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }\n    .media-logo-item { flex-shrink: 0; width: 120px; height: 56px; display: flex; align-items: center; justify-content: center; margin: 0 20px; }\n    .media-logo-item img { height: 36px; object-fit: contain; opacity: .65; filter: grayscale(1); transition: opacity .3s, filter .3s; }\n    .media-logo-item img:hover { opacity: 1; filter: grayscale(0); }\n\n    /* \u2500\u2500 FAQ \u2500\u2500 */\n    #faq { background: var(--ivory); }\n    .faq-list { max-width: 720px; margin: 40px auto 0; display: flex; flex-direction: column; gap: 12px; }\n    .faq-item { background: #fff; border-radius: 18px; border: 1px solid var(--border); overflow: hidden; }\n    .faq-q { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 18px 20px; background: none; border: none; cursor: pointer; font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 500; color: var(--dark); text-align: left; gap: 16px; }\n    .faq-icon { width: 22px; height: 22px; flex-shrink: 0; color: var(--gold); transition: transform .25s; }\n    .faq-item.open .faq-icon { transform: rotate(180deg); }\n    .faq-a { max-height: 0; overflow: hidden; transition: max-height .35s ease, padding .35s ease; }\n    .faq-item.open .faq-a { max-height: 300px; }\n    .faq-a-inner { padding: 0 20px 18px; font-size: 14px; color: var(--muted); line-height: 1.7; border-top: 1px solid var(--border); padding-top: 14px; }\n\n    /* \u2500\u2500 CTA BANNER \u2500\u2500 */\n    #cta { background: linear-gradient(135deg, #FFF5E8, #FDE8EC 50%, #FFF5E8); padding: 80px 24px; text-align: center; position: relative; overflow: hidden; }\n    #cta::before { content: '\u0950'; font-family: 'Cormorant Garamond', serif; font-size: 260px; color: rgba(128,0,0,.04); position: absolute; right: 40px; top: 50%; transform: translateY(-50%); pointer-events: none; }\n    .cta-heading { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(28px, 4vw, 52px); color: var(--dark); margin-bottom: 16px; }\n    .cta-sub { color: var(--muted); font-size: 15px; max-width: 520px; margin: 0 auto 32px; line-height: 1.7; }\n    .cta-footnote { color: rgba(92,74,66,.5); font-size: 12px; margin-top: 16px; }\n\n    /* \u2500\u2500 FOOTER \u2500\u2500 */\n    footer { background: var(--dark); color: rgba(255,255,255,.7); }\n    .footer-main { padding: 56px 24px; max-width: 1200px; margin: 0 auto; }\n    .footer-logo-wrap { text-align: center; padding-bottom: 36px; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 36px; }\n    .footer-logo { height: 48px; object-fit: contain; filter: drop-shadow(0 0 5px rgba(255,255,255,.8)) brightness(1.3); }\n    .footer-tagline { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 300; font-style: italic; color: rgba(255,255,255,.8); max-width: 640px; margin: 20px auto 0; line-height: 1.6; }\n    .footer-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-bottom: 36px; }\n    .footer-col h4 { font-family: 'Cormorant Garamond', serif; font-size: 15px; font-weight: 600; color: var(--gold); margin-bottom: 14px; letter-spacing: .05em; }\n    .footer-col a, .footer-col p { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,.6); text-decoration: none; margin-bottom: 8px; transition: color .2s; }\n    .footer-col a:hover { color: var(--gold); }\n    .pg-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-bottom: 14px; }\n    .pg-item { background: #fff; border-radius: 6px; padding: 4px; height: 32px; display: flex; align-items: center; justify-content: center; }\n    .pg-item img { height: 20px; object-fit: contain; }\n    .wa-btn { display: inline-flex; align-items: center; gap: 8px; background: #25D366; color: #fff; font-size: 12px; font-weight: 600; padding: 8px 16px; border-radius: 999px; text-decoration: none; margin-top: 6px; transition: background .2s; }\n    .wa-btn:hover { background: #1DA851; }\n    .footer-bottom { border-top: 1px solid rgba(255,255,255,.1); padding-top: 20px; }\n    .social-row { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 16px; }\n    .social-label { color: rgba(255,255,255,.4); font-size: 12px; }\n    .social-icon { width: 36px; height: 36px; border-radius: 50%; border: 1px solid rgba(255,255,255,.15); background: rgba(255,255,255,.06); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,.6); text-decoration: none; transition: color .2s, border-color .2s, background .2s; }\n    .social-icon:hover { color: var(--gold); border-color: rgba(201,162,39,.5); background: rgba(255,255,255,.1); }\n    .social-icon svg { width: 16px; height: 16px; }\n    .footer-cr { display: flex; justify-content: space-between; font-size: 12px; color: rgba(255,255,255,.35); flex-wrap: wrap; gap: 8px; }\n    .disclaimer { background: #1A120C; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,.05); text-align: center; font-size: 11px; color: rgba(255,255,255,.35); line-height: 1.7; max-width: 900px; margin: 0 auto; }\n\n    /* \u2500\u2500 FLOATING WA \u2500\u2500 */\n    .floating-wa { position: fixed; bottom: 24px; right: 24px; z-index: 50; width: 56px; height: 56px; border-radius: 50%; background: #25D366; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(37,211,102,.3); text-decoration: none; transition: transform .2s, box-shadow .2s; animation: wa-pulse 2.5s infinite; }\n    .floating-wa:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(37,211,102,.4); }\n    @keyframes wa-pulse { 0%,100%{box-shadow:0 4px 20px rgba(37,211,102,.3)} 50%{box-shadow:0 4px 32px rgba(37,211,102,.5)} }\n    .floating-wa svg { width: 28px; height: 28px; fill: #fff; }\n\n    /* \u2500\u2500 BUTTONS \u2500\u2500 */\n    .btn-maroon { background: var(--maroon); color: #fff; font-weight: 600; font-size: 14px; padding: 14px 40px; border-radius: 999px; border: none; cursor: pointer; transition: background .2s, transform .2s, box-shadow .2s; box-shadow: 0 4px 20px rgba(128,0,0,.2); text-decoration: none; display: inline-block; }\n    .btn-maroon:hover { background: var(--maroon2); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(128,0,0,.25); }\n    .center { text-align: center; }\n\n    /* \u2500\u2500 RESPONSIVE \u2500\u2500 */\n    @media (max-width: 1200px) { .experts-grid { grid-template-columns: repeat(4, 1fr); } }\n    @media (max-width: 900px) {\n      nav { padding: 14px 20px; }\n      nav .nav-links, nav .nav-cta { display: none; }\n      .hamburger { display: flex; }\n      .hero-content { padding: 24px 20px; }\n      .hero-inner { text-align: center; max-width: 100%; }\n      .hero-quote { margin: 0 auto 28px; }\n      .hero-